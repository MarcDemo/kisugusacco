DJANGO_SECRET_KEY='replace-this-with-a-long-random-production-secret'
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
DJANGO_TIME_ZONE=Africa/Kampala

# Use sqlite locally, mysql on cPanel production.
DB_ENGINE=mysql
DB_NAME=cpaneluser_kisugu
DB_USER=cpaneluser_kisugu
DB_PASSWORD='replace-this-with-the-mysql-password'
DB_HOST=localhost
DB_PORT=3306

# Keep production uploads and collected static files outside Git.
DJANGO_MEDIA_ROOT=/home/cpaneluser/kisugu_media
DJANGO_STATIC_ROOT=/home/cpaneluser/kisugu_staticfiles

# Email credentials must stay on the server, never in Git.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=info@example.com
EMAIL_HOST_PASSWORD='replace-this-with-app-password'
DEFAULT_FROM_EMAIL=info@example.com

# Backups
BACKUP_DIR=/home/cpaneluser/backups/kisugu
BACKUP_RETENTION_DAYS=84
RUN_PRE_DEPLOY_BACKUP=0
